@inherits LayoutComponentBase
@inject ThemeService ThemeService

<MudThemeProvider Theme="@_activeTheme" IsDarkMode="@ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6" Class="ml-3">
            SoopWorkshop
        </MudText>

        <MudSpacer />

        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit">
            <MudMenuItem OnClick="@(() => ThemeService.SetTheme(AppTheme.Light))">
                ☀️ Light
            </MudMenuItem>
            <MudMenuItem OnClick="@(() => ThemeService.SetTheme(AppTheme.Dark))">
                🌙 Dark
            </MudMenuItem>
            <MudMenuItem OnClick="@(() => ThemeService.SetTheme(AppTheme.Oled))">
                ⚫ OLED
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="mt-1">SOOP Workshop</MudText>
        </MudDrawerHeader>

        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Info">
                Info
            </MudNavLink>

            <MudDivider Class="my-2" />

            @* Wird in Schritt 3 implementiert *@
            @* <TaskSidebarList /> *@

        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>